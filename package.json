{
    "name": "bennett-toolbox",
    "private": true,
    "version": "1.0.0",
    "description": "多功能工具箱桌面应用",
    "author": "李海波 <bennettmail@163.com>",
    "license": "MIT",
    "homepage": "https://github.com/bennett-lee/bennett-toolbox#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/bennett-lee/bennett-toolbox.git"
    },
    "bugs": {
        "url": "https://github.com/bennett-lee/bennett-toolbox/issues"
    },
    "keywords": [
        "electron",
        "react",
        "toolbox",
        "markdown",
        "heic",
        "desktop-app"
    ],
    "main": "dist-electron/main.js",
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build && electron-builder",
        "build:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false npm run build -- --mac",
        "build:win": "npm run build -- --win --x64",
        "preview": "vite preview",
        "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
        "electron:build": "vite build && electron-builder",
        "setup:markitdown": "zsh scripts/build_markitdown_binary.sh",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "dependencies": {
        "gifenc": "^1.0.3",
        "heic-convert": "^2.1.0",
        "jszip": "^3.10.1",
        "pdfjs-dist": "^5.6.205",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^18.2.43",
        "@types/react-dom": "^18.2.17",
        "@vitejs/plugin-react": "^4.2.1",
        "concurrently": "^8.2.2",
        "electron": "^28.1.0",
        "electron-builder": "^26.8.1",
        "jsdom": "^26.1.0",
        "typescript": "^5.2.2",
        "vite": "^5.0.8",
        "vite-plugin-electron": "^0.28.0",
        "vite-plugin-electron-renderer": "^0.14.5",
        "vitest": "^3.2.4",
        "wait-on": "^7.2.0"
    },
    "build": {
        "appId": "com.bennett.toolbox",
        "productName": "Bennett Toolbox",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "dist-electron/**/*"
        ],
        "extraResources": [
            {
                "from": "vendor/markitdown",
                "to": "markitdown",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "mac": {
            "target": "dmg"
        },
        "win": {
            "target": "nsis"
        }
    }
}
